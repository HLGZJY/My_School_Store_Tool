{
  "bsonType": "object",
  "description": "微信凭证存储 - 存储公众号登录凭证",
  "required": ["authKey", "token"],
  "permission": {
    "read": "doc.authKey == authKey || 'sync' in permissions || 'all' in permissions",
    "create": "authKey == 'wc_' + token",
    "update": "doc.authKey == authKey",
    "delete": "doc.authKey == authKey",
    "count": true
  },
  "properties": {
    "_id": {
      "description": "记录ID"
    },
    "authKey": {
      "bsonType": "string",
      "description": "凭证Key，格式：wc_xxx"
    },
    "token": {
      "bsonType": "string",
      "description": "微信token"
    },
    "cookies": {
      "bsonType": "array",
      "description": "登录cookie数组"
    },
    "nickName": {
      "bsonType": "string",
      "description": "公众号名称"
    },
    "headImg": {
      "bsonType": "string",
      "description": "公众号头像"
    },
    "expires": {
      "bsonType": "number",
      "description": "过期时间戳"
    },
    "createTime": {
      "bsonType": "number",
      "description": "创建时间"
    }
  }
}
